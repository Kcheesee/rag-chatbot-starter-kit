# =============================================================================
# rag-chat-agent — Federal / PubSec environment reference (Tier 3)
# =============================================================================
# Opt-in tier. DEPLOYMENT_MODE=federal activates GovCloud routing, PII
# redaction, NIST audit logging, SAML auth, and the 508 accessibility build.
# Commercial deployments are entirely unaffected.
#
# The env schema REJECTS this config unless the federal invariants hold:
#   - LLM_PROVIDER ∈ {bedrock-gov, azure-gov, internal}
#   - AWS_REGION is a GovCloud region when LLM_PROVIDER=bedrock-gov
#   - VECTOR_STORE != pinecone (no FedRAMP authorization)
#   - PGVECTOR_SSL=require
#   - AUTH_ENABLED=true
# See federal/FEDERAL.md and CONFIG.md#federal-deployment.
# =============================================================================

# ── Mode ─────────────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=federal
IMPACT_LEVEL=high                    # low | moderate | high
DATA_CLASSIFICATION=CUI              # public | CUI | sensitive

# ── LLM via GovCloud ─────────────────────────────────────────────────────────
LLM_PROVIDER=bedrock-gov
AWS_REGION=us-gov-west-1
AWS_BEDROCK_MODEL=anthropic.claude-sonnet-4-6
# Zero static credentials — ECS task role / instance profile assumed at runtime.

# ── Embeddings (inside the GovCloud boundary) ────────────────────────────────
EMBEDDING_PROVIDER=bedrock
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── Vector store ─────────────────────────────────────────────────────────────
VECTOR_STORE=pgvector
PGVECTOR_HOST=your-cluster.us-gov-west-1.rds.amazonaws.com
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=rag
PGVECTOR_USER=rag
PGVECTOR_SSL=require
PGVECTOR_TABLE=rag_chunks

# ── PII redaction ────────────────────────────────────────────────────────────
PII_REDACTION_ENABLED=true
PII_REDACTION_PROVIDER=aws-comprehend

# ── Audit logging (NIST 800-53 AU-2, AU-12) ──────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_TARGET=cloudwatch
AUDIT_LOG_RETENTION_DAYS=1095         # 3 years
LOG_QUERY_HASHES=true                 # never store raw query text
LOG_RESPONSES=false                   # responses may contain PII

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_ENABLED=true
AUTH_PROVIDER=saml
SAML_ENTRY_POINT=https://agency-idp.gov/sso
SAML_ISSUER=rag-chat-agent

# ── 508 accessibility ────────────────────────────────────────────────────────
A11Y_MODE=true
STREAM_BUFFER_MS=500

# ── Data residency ───────────────────────────────────────────────────────────
ALLOWED_REGIONS=us-gov-west-1,us-gov-east-1
ENFORCE_DATA_RESIDENCY=true

# ── Hybrid retrieval (recommended for exact-match federal terminology) ───────
HYBRID_SEARCH=true

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_VERSION=0.1.0
