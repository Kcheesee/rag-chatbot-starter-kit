# =============================================================================
# rag-chat-agent — Commercial deployment environment reference
# =============================================================================
# Copy to `.env.local` (Tier 1 dev) or `.env` (Tier 2 enterprise) and fill in.
# The federal tier (Tier 3) uses `federal/.env.federal.example` instead.
#
# Everything here is read & validated ONCE by packages/rag-core's env schema
# (zod). No other module reads process.env directly. See CONFIG.md for the full
# explanation of every option and which fields are required per provider.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Tier 1 (dev):        anthropic | openai
# Tier 2 (enterprise): bedrock | vertex | azure-openai
# Tier 3 (federal):    bedrock-gov | azure-gov | internal
LLM_PROVIDER=anthropic
# Default kept lean for a boilerplate. claude-opus-4-8 is the most capable model;
# see CONFIG.md#choosing-a-model.
LLM_MODEL=claude-sonnet-4-6

# Tier 1 keys (dev only — never use a personal key in shared/production envs)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Tier 2 — AWS Bedrock (no static key; IAM role / `aws sso login` supplies creds)
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-sonnet-4-6

# Tier 2 — Google Vertex AI (Application Default Credentials at runtime)
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=claude-sonnet-4-6

# Tier 2 — Azure OpenAI Service (key via Key Vault / Managed Identity, not here)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-prod
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Tier 3 — Bedrock GovCloud (set AWS_REGION to a us-gov-* region)
# AWS_REGION=us-gov-west-1

# Tier 3 — Azure Government (set the .us endpoint)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.us

# Tier 3 — Internal / 1P / research-lab model serving (OpenAI-compatible + mTLS)
INTERNAL_LLM_ENDPOINT=https://models.agency-internal.gov/v1
INTERNAL_LLM_MODEL=agency-llm-v2
INTERNAL_LLM_CERT_PATH=/run/secrets/client.crt
INTERNAL_LLM_KEY_PATH=/run/secrets/client.key

# ── Embeddings ───────────────────────────────────────────────────────────────
# NOTE: the dev quickstart (Anthropic LLM + Chroma) still needs an embeddings
# provider. The default below requires OPENAI_API_KEY. Anthropic has no first-
# party embeddings API — use `voyage` or `cohere` for an OpenAI-free dev path.
EMBEDDING_PROVIDER=openai          # openai | cohere | voyage | bedrock | vertex
EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=
VOYAGE_API_KEY=

# ── Vector Store (pick one) ──────────────────────────────────────────────────
VECTOR_STORE=chroma                # chroma | pinecone | pgvector | weaviate
CHROMA_URL=http://localhost:8000
PINECONE_API_KEY=
PINECONE_INDEX=
WEAVIATE_URL=
WEAVIATE_API_KEY=
# pgvector (Tier 2/3 — Aurora or self-hosted Postgres)
PGVECTOR_HOST=
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=rag
PGVECTOR_USER=rag
PGVECTOR_PASSWORD=
PGVECTOR_SSL=prefer                # require (enforced under federal) | prefer | disable
PGVECTOR_TABLE=rag_chunks

# ── Ingestion source security (admin /api/ingest; see CONFIG.md#ingestion) ────
# Defaults already block SSRF to private/loopback/link-local/metadata IPs. These
# tighten it further; the trusted local CLI can opt out where noted.
# If set, file ingestion is confined to this directory (path-containment + symlink
# escape guard). Unset → local paths are trusted (correct for the CLI).
INGEST_ROOT=
# Comma-separated host allowlist for the url/sitemap loaders. ".example.com"
# matches subdomains. Unset → any PUBLIC host (still subject to the private-IP block).
INGEST_URL_ALLOWLIST=
INGEST_MAX_BYTES=10000000          # per-fetch body cap (bytes); guards against bombs
INGEST_TIMEOUT_MS=15000            # per-fetch timeout (ms)
# DANGER: true re-opens SSRF to private networks. Only for the trusted local CLI
# crawling an intranet — never for the hosted/admin ingest surface.
INGEST_ALLOW_PRIVATE_NETWORKS=false

# ── Deployment Target ────────────────────────────────────────────────────────
DEPLOYMENT_TARGET=web              # web | slack | teams | widget | all

# ── Slack Bot ────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...

# ── Teams Bot ────────────────────────────────────────────────────────────────
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ── App Config ───────────────────────────────────────────────────────────────
BOT_NAME="Aria"
# Sets tone only — the grounding rules (answer only from sources + cite them) are enforced separately.
# Tip: the chat UI renders plain text, so a "no Markdown" instruction keeps stray ** asterisks out of replies.
BOT_PERSONA="You are a warm, caring, and genuinely helpful assistant. Speak in a natural, conversational, reassuring tone — like a friendly, knowledgeable person who wants to help, not a stiff manual. Explain things clearly and gently, and write in plain, flowing sentences. Do not use Markdown formatting such as asterisks, bold, headings, or bullet characters; weave any list of items into natural prose. Keep bracketed source citations like [1] exactly as they appear."
MAX_TOKENS=1024
TEMPERATURE=0.2
TOP_K_RESULTS=10                   # retrieve this many, rerank down to TOP_K_AFTER_RERANK
TOP_K_AFTER_RERANK=5
RERANKER=hybrid                    # hybrid (no deps) | cohere (cross-encoder, needs COHERE_API_KEY)
# RERANK_MODEL=rerank-english-v3.0 # override Cohere's rerank model (RERANKER=cohere only)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
HYBRID_SEARCH=false                # true = BM25 + semantic (recommended for federal)

# ── Response cache ───────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.93
CACHE_INVALIDATE_ON_MODEL_CHANGE=true

# ── Accuracy guardrails ──────────────────────────────────────────────────────
MIN_RETRIEVAL_CONFIDENCE=0.70
# true = an answer with ZERO valid citations is escalated for human handoff rather
# than served as authoritative. Recommended for regulated/high-stakes deployments.
STRICT_GROUNDING=false
FAITHFULNESS_CHECK=false           # true for high-stakes / regulated deployments
FAITHFULNESS_THRESHOLD=0.85

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secure-by-default: with AUTH_ENABLED=true and NO verifier configured, the API
# FAILS CLOSED (rejects every request). Wire a real verifier with setTokenVerifier()
# (Clerk/NextAuth/JWKS/SAML), OR use AUTH_STATIC_TOKENS, OR — local dev only — set
# AUTH_ALLOW_INSECURE_TOKENS=true. See CONFIG.md#auth.
AUTH_ENABLED=false
AUTH_PROVIDER=clerk                # clerk | nextauth | saml (enterprise/federal)
CLERK_SECRET_KEY=
SAML_ENTRY_POINT=
SAML_ISSUER=rag-chat-agent
AUTH_RATE_LIMIT=50                 # requests/min per user or IP on /api/chat
# Built-in static-token verifier: a JSON array of identities. `admin:true` is
# required to call /api/ingest; `namespaces` pins which tenant namespaces the
# identity may use (omit → AUTH_DEFAULT_NAMESPACE). Malformed JSON fails loudly.
# AUTH_STATIC_TOKENS=[{"token":"REPLACE_ME","userId":"ops","admin":true,"namespaces":["acme"]}]
AUTH_STATIC_TOKENS=
# DEV ONLY. Treat ANY non-empty bearer token as an opaque user id, with no tenant
# scope. Never enable in production; rejected outright under DEPLOYMENT_MODE=federal.
AUTH_ALLOW_INSECURE_TOKENS=false
# Namespace granted to a verified identity that doesn't pin its own `namespaces`.
AUTH_DEFAULT_NAMESPACE=default

# ── Session memory ───────────────────────────────────────────────────────────
SESSION_STORE=memory               # memory | redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
SESSION_MAX_TURNS=20

# ── PII redaction (enterprise / federal) ─────────────────────────────────────
PII_REDACTION_ENABLED=false        # true for any deployment handling personal data
PII_REDACTION_PROVIDER=presidio    # presidio | aws-comprehend
PRESIDIO_URL=http://localhost:5002
PRESIDIO_MIN_CONFIDENCE=0          # 0 = redact every detection; raise (e.g. 0.6) to drop low-confidence false positives

# ── Audit logging ────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=false            # true for enterprise and federal
AUDIT_LOG_TARGET=console           # console | cloudwatch | s3 | splunk
AUDIT_LOG_RETENTION_DAYS=90
LOG_QUERY_HASHES=false             # true for federal — never log raw query text
LOG_RESPONSES=false                # responses may contain PII — off by default

# ── Widget ───────────────────────────────────────────────────────────────────
WIDGET_ALLOWED_ORIGINS=http://localhost:3000

# ── Federal mode (Tier 3 only) ───────────────────────────────────────────────
DEPLOYMENT_MODE=standard           # standard | federal
IMPACT_LEVEL=low                   # low | moderate | high
DATA_CLASSIFICATION=public         # public | CUI | sensitive
A11Y_MODE=false                    # true enables WCAG 2.1 AA build + stream buffering
STREAM_BUFFER_MS=500
ENFORCE_DATA_RESIDENCY=false
ALLOWED_REGIONS=us-east-1,us-west-2

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_VERSION=0.1.0
