{
  "name": "@rag-chat-agent/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Next.js 14 App Router chat UI + streaming API.",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:widget && next build",
    "build:widget": "esbuild ../widget/src/loader.ts --bundle --minify --format=iife --target=es2018 --outfile=public/widget.js",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@rag-chat-agent/audit-logger": "*",
    "@rag-chat-agent/ingestion": "*",
    "@rag-chat-agent/llm-adapters": "*",
    "@rag-chat-agent/rag-core": "*",
    "@rag-chat-agent/ui-components": "*",
    "@rag-chat-agent/vector-adapters": "*",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.24.2"
  }
}
